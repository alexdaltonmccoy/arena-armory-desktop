{
  "name": "arena-armory-desktop",
  "version": "1.2.0",
  "description": "Arena Armory desktop companion: imports arena matches recorded by the ArenaArmory WoW addon and uploads them to arenaarmory.com",
  "main": "./out/main/index.js",
  "author": "ArenaArmory",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "tsx test/parse.test.ts",
    "dist": "electron-vite build && electron-builder --win --publish never"
  },
  "build": {
    "appId": "com.arenaarmory.desktop",
    "productName": "Arena Armory",
    "files": [
      "out/**",
      "build/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "artifactName": "Arena-Armory-Setup.${ext}",
      "oneClick": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "icon": "build/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "alexdaltonmccoy",
      "repo": "arena-armory-desktop",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "luaparse": "^0.3.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/luaparse": "^0.2.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  }
}
